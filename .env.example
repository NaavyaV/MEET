# Required for real accounts and persistence
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Required only for LLM extraction and profile/relevance reasoning.
# The app deliberately uses Groq's lowest-cost production text model.
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Optional live opportunity sources. A configured source never mixes in sample cards.
# Eventbrite's public location-search endpoint is retired, so MEET intentionally does not call this key.
EVENTBRITE_API_KEY=
# Comma-separated RSS or ICS feeds (up to six). Verified DFW starters:
# MEET_RSS_FEED_URL=https://www.tddallas.org/Events/RSS,https://calendar.utdallas.edu/calendar.ics?event_types%5B%5D=30645184548410,https://calendar.utdallas.edu/calendar.ics?event_types%5B%5D=31183765024118,https://calendar.utdallas.edu/calendar.ics?event_types%5B%5D=31183766846447,https://calendar.unt.edu/calendar.ics?event_types%5B%5D=38308632250293
# Nationwide/online starters: US-RSE events, NSF events, and MyNext.Events:
# MEET_RSS_FEED_URL=https://us-rse.org/feeds/events.xml,https://www.nsf.gov/rss/rss_www_events.xml,https://mynext.events/events.rss
MEET_RSS_FEED_URL=
# Add only pages that their owner permits you to crawl. MEET checks robots.txt
# before each fetch; candidate starting points: https://us-rse.org/events/, https://www.joineta.org/events, https://events.mlh.io/
CRAWL_SEED_URLS=

# Compliant open-web discovery. Keep keys server-side; never use NEXT_PUBLIC_ for them.
EXA_API_KEY=
WEB_DISCOVERY_ENABLED=true
WEB_DISCOVERY_MAX_QUERIES=6
WEB_DISCOVERY_MAX_RESULTS=48
WEB_DISCOVERY_MAX_FETCHES=15
WEB_DISCOVERY_MAX_PAGES_PER_DOMAIN=2
# Leave these blank to use no additional region restriction or domain blocklist.
# MEET still applies its built-in exclusions for social, Eventbrite, and known event aggregators.
WEB_DISCOVERY_ALLOWED_REGIONS=
WEB_DISCOVERY_BLOCKED_DOMAINS=
WEB_DISCOVERY_USER_AGENT=MEETOpportunityBot/1.0 (+https://your-domain.example/bot)
MEET_LOCATION_COUNTRY_CODE=
# Optional: let Groq diversify deterministic queries; bounded to the configured max.
WEB_DISCOVERY_REFINE_QUERIES=false

# Required to send scheduled digest email.
RESEND_API_KEY=
DIGEST_FROM_EMAIL=MEET <digest@example.com>

# Required by the Vercel Cron-compatible scheduled refresh endpoint.
CRON_SECRET=
