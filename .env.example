# Required for real accounts and persistence
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Required only for LLM extraction and profile/relevance reasoning.
# The app deliberately uses Groq's lowest-cost production text model.
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Optional live opportunity sources. Without these, MEET runs in clearly labelled demo mode.
EVENTBRITE_API_KEY=
# Legacy alternative for older Eventbrite integrations.
EVENTBRITE_PRIVATE_TOKEN=
MEET_RSS_FEED_URL=
CRAWL_SEED_URLS=

# Compliant open-web discovery. Keep keys server-side; never use NEXT_PUBLIC_ for them.
EXA_API_KEY=
WEB_DISCOVERY_ENABLED=true
WEB_DISCOVERY_MAX_QUERIES=6
WEB_DISCOVERY_MAX_RESULTS=30
WEB_DISCOVERY_MAX_FETCHES=15
WEB_DISCOVERY_MAX_PAGES_PER_DOMAIN=2
WEB_DISCOVERY_ALLOWED_REGIONS=
WEB_DISCOVERY_BLOCKED_DOMAINS=
WEB_DISCOVERY_USER_AGENT=MEETOpportunityBot/1.0 (+https://your-domain.example/bot)
MEET_LOCATION_COUNTRY_CODE=
# Optional: let Groq diversify deterministic queries; bounded to the configured max.
WEB_DISCOVERY_REFINE_QUERIES=false

# Required to send scheduled digest email.
RESEND_API_KEY=
DIGEST_FROM_EMAIL=MEET <digest@example.com>

# Required by the Vercel Cron-compatible scheduled refresh endpoint.
CRON_SECRET=
